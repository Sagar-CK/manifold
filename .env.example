## Gemini (embeddings)
# Required for search + file embedding: backend reads this key and Settings can override it locally.
MANIFOLD_GEMINI_API_KEY=your_google_gemini_api_key

## Qdrant (vector DB)
# Local dev (recommended): Docker Qdrant gRPC endpoint from `pnpm qdrant:up`.
MANIFOLD_QDRANT_URL=http://127.0.0.1:6334
# Qdrant dashboard for local dev: http://127.0.0.1:6333/dashboard
# Packaged app / CI: leave empty so the app auto-starts the bundled Qdrant binary from resources.
# Dev without Docker: clear MANIFOLD_QDRANT_URL and run `pnpm setup:binaries` to install the local Qdrant binary.
MANIFOLD_QDRANT_API_KEY=

## Optional runtime overrides
MANIFOLD_LOG=
MANIFOLD_PDFIUM_LIB_DIR=
# Optional directory containing `ffmpeg` and `ffprobe` binaries for video thumbnails.
MANIFOLD_FFMPEG_BIN_DIR=
