## Gemini (embeddings)
# Required for search + file embedding: backend reads this (same key for both).
MANIFOLD_GEMINI_API_KEY=your_google_gemini_api_key
# Optional fallback name supported by the backend.
GOOGLE_GENERATIVE_AI_API_KEY=
# Optional: only needed if you call Gemini from the browser in dev (not used for search anymore).
VITE_GOOGLE_GENERATIVE_AI_API_KEY=

## Qdrant (vector DB)
# Local dev (recommended): Docker Qdrant from `pnpm qdrant:up` — same host/ports as below.
MANIFOLD_QDRANT_URL=http://127.0.0.1:6333
# Packaged app / CI: leave empty so the app auto-starts the bundled Qdrant binary from resources.
# Dev without Docker: clear MANIFOLD_QDRANT_URL and run `pnpm setup:binaries` to install the local Qdrant binary.
# Optional: gRPC override (defaults are inferred from MANIFOLD_QDRANT_URL)
MANIFOLD_QDRANT_GRPC_URL=
MANIFOLD_QDRANT_API_KEY=

