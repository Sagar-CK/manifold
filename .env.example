## Convex
# Used by `npx convex dev` / `npx convex codegen`
CONVEX_DEPLOYMENT=dev:your-deployment-name

# Used by the desktop app (Vite frontend)
VITE_CONVEX_URL=https://your-deployment.convex.cloud

## Gemini (embeddings)
# Used by the desktop app to call Gemini embeddings directly.
VITE_GOOGLE_GENERATIVE_AI_API_KEY=your_google_gemini_api_key

