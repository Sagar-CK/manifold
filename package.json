{
  "name": "manifold",
  "productName": "Manifold",
  "private": true,
  "version": "0.1.6",
  "type": "module",
  "main": "dist-electron/bootstrap.js",
  "scripts": {
    "dev": "node ./scripts/run-dev.mjs",
    "build": "pnpm typecheck && vite build",
    "dist": "pnpm build && electron-builder --publish=never",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src electron package.json vite.config.ts tsconfig.json tsconfig.app.json tsconfig.node.json biome.json",
    "format": "biome format --write src electron package.json vite.config.ts tsconfig.json tsconfig.app.json tsconfig.node.json biome.json",
    "check": "pnpm lint && pnpm typecheck",
    "qdrant:up": "docker compose up -d",
    "qdrant:down": "docker compose down",
    "setup:binaries": "node ./scripts/setup-binaries.mjs",
    "setup:dev": "node ./scripts/setup-dev.mjs"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@hugeicons/core-free-icons": "^4.1.1",
    "@hugeicons/react": "^1.1.6",
    "@napi-rs/canvas": "^0.1.100",
    "@qdrant/js-client-rest": "^1.17.0",
    "@saehrimnir/druidjs": "^0.8.0",
    "@uiw/color-convert": "2.10.3",
    "@uiw/react-color-shade-slider": "2.10.3",
    "@uiw/react-color-wheel": "2.10.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "next-themes": "^0.4.6",
    "p-limit": "^7.3.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^5.7.284",
    "radix-ui": "^1.4.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.13.2",
    "shadcn": "^4.6.0",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.4",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "electron": "^41.5.0",
    "electron-builder": "^26.8.1",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.7"
  },
  "build": {
    "appId": "com.sagarchethankumar.manifold",
    "productName": "Manifold",
    "directories": {
      "output": "release"
    },
    "icon": "build/icon.png",
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "public/manifold-icon-128.png",
      "package.json",
      "node_modules/sharp/**/*",
      "node_modules/@img/**/*",
      "node_modules/@napi-rs/**/*"
    ],
    "npmRebuild": false,
    "asarUnpack": [
      "**/node_modules/sharp/**/*",
      "**/node_modules/@img/**/*",
      "**/node_modules/@napi-rs/canvas/**/*",
      "**/node_modules/@napi-rs/canvas-*/**/*"
    ],
    "extraResources": [
      {
        "from": "resources",
        "to": "resources",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.png",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "build/icon.png",
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    }
  }
}
